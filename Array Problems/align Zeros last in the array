package array_problems;

public class zeros {
	public static void main(String[] args) {
		int[] nums = {0,1,0,3,12};
		int i =0;
		int j=0;
		while(i < nums.length) {
			if(nums[i] != 0) {
				int temp = nums[i];
				nums[i] = nums[j];
				nums[j] = temp;
				i++;
				j++;
			}else 
			{	
			i++;
			}
	}
         for(int k =0; k<nums.length;k++) {
		System.out.print(nums[k]+ " ");
         }
}
}
