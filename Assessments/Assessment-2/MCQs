//2. 0 -->This happens due to constructor calling overridden method before child initialization.Runtime Polymorphism.
class A {
	A() {
		show();
	}
	void show() {
		System.out.print("A ");
	}
}
class B extends A {
	int x = 10;
	void show() {
		System.out.print(x + " ");
	}
}
public class Test {
	public static void main(String[] args) {
		new B();
	}
}

