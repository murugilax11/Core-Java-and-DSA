//4. I1
interface I1 {
	default void show() {
		System.out.print("I1 ");
	}
}
interface I2 {
	default void show() {
		System.out.print("I2 ");
	}
}
class A implements I1, I2 {
	public void show() {
		I1.super.show();
	}
}
public class Test {
	public static void main(String[] args) {
		new A().show();
	}
}

