public class subSequences {
    public static void main(String[] args) {
        String s ="ABC";
        int size = 1 << s.length();
        for(int i =0; i <size;i++){
            String subSeq = "";
            for(int j=0; j < s.length(); j++){
                if((i & (1 << j)) != 0){
                    subSeq += s.charAt(j);
                }
            }
            System.out.println(subSeq);
        }
    }
}
